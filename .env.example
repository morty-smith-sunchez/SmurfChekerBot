TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_PROXY=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_MTPROXY_SERVER=127.0.0.1
TELEGRAM_MTPROXY_PORT=1443
TELEGRAM_MTPROXY_SECRET=
STEAM_API_KEY=
# Через запятую: ваш Telegram user id (число из @userinfobot). Зеркало сообщений — только сюда.
ADMIN_USER_IDS=
# Логины без @ (те же /admin_*). Числа сюда тоже можно — засчитаются как user id.
ADMIN_USERNAMES=
# true — дублировать каждое текстовое сообщение пользователей админам (шумно)
ADMIN_MESSAGE_MIRROR=false
OPENDOTA_API_KEY=
STRATZ_API_KEY=
HTTP_MAX_CONNECTIONS=
HTTP_MAX_KEEPALIVE_CONNECTIONS=
MATCH_PLAYER_PROBE_CONCURRENCY=
DONATION_TEXT=
DONATION_CARD=
DONATION_URL=

# Рост: ссылка на ваш канал (https://t.me/...). Появится кнопка в меню и под инлайн-кнопками отчёта.
PROMO_CHANNEL_URL=
PROMO_CHANNEL_BUTTON_TEXT=Наш канал
# Свой HTML-блок в /start вместо авто-строки про канал (оставьте пустым если не нужно)
PROMO_START_LINE_HTML=
# Отдельное сообщение после успешного /analyze (HTML). Интервал на одного пользователя — ниже.
PROMO_SPONSORED_AFTER_ANALYZE_HTML=
# Секунды между показами спонсорского блока одному пользователю (по умолчанию 12 ч)
PROMO_SPONSORED_COOLDOWN_SECONDS=43200

# Кнопка канала только под карточкой /analyze (последняя строка; допускается https://t.me/+invitehash)
ANALYZE_CHANNEL_URL=
ANALYZE_CHANNEL_BUTTON_TEXT=Telegram-канал

# Профиль в Telegram для связи (https://t.me/yourname). Текст кнопки-ссылки — необязательно.
SUPPORT_TELEGRAM_URL=
SUPPORT_TELEGRAM_LABEL=Написать автору
